# Server (npm run server)
PORT=3000

# Stripe — secret key from Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_xxxxxx

# Webhook signing secret:
# - Dashboard → Developers → Webhooks → your endpoint → Signing secret
# - OR from: stripe listen --forward-to localhost:3000/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_xxxxxx

# Activation code emailed after successful checkout
ACTIVATION_CODE=ABCD-1234PINGSH002

# SMTP (Gmail, SendGrid, etc.)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password
SMTP_FROM="Ping Shuai" <your-email@example.com>
